# =====================================================================
# Onicanal — variáveis de ambiente
# Copie para .env.local (desenvolvimento) ou cadastre no Vercel (produção).
# =====================================================================

# --- Banco de dados (Supabase Postgres) -----------------------------
# Connection pooling (PgBouncer) — usado pelo app em runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Conexão direta — usada por prisma migrate / db push
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- NextAuth -------------------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-esse-valor-por-um-segredo-aleatorio"
# Em produção, é a URL do site no Vercel; em dev pode ficar em branco
NEXTAUTH_URL="http://localhost:3000"

# --- Criptografia de tokens (Tiny etc) ------------------------------
# AES-256-GCM. Gere com: openssl rand -hex 32  (deve dar 64 caracteres hex)
ENCRYPTION_KEY="troque-por-uma-chave-hex-de-64-caracteres-aleatorios"

# --- Usuário admin (seed) -------------------------------------------
# Usados pelo script `npm run seed` para criar seu login inicial.
ADMIN_EMAIL="voce@exemplo.com"
ADMIN_PASSWORD="trocar-depois-do-primeiro-login"
ADMIN_NAME="Onicanal Admin"

# --- Sincronização Tiny ---------------------------------------------
# Aceitamos os tokens só via tela de Configurações (criptografados no banco).
# Esta variável serve apenas como fallback opcional para ambiente local.
# TINY_DEFAULT_HISTORICO_MESES=12

# --- Cron (Vercel) --------------------------------------------------
# Segredo para autenticar chamadas do Vercel Cron.
# Gere com: openssl rand -hex 32
CRON_SECRET="troque-por-um-segredo-aleatorio-de-64-hex"
